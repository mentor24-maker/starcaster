{
  "version": 2,
  "routes": [
    {
      "src": "/(.*\\.(?:js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|webp|ttf|eot|map)$)",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/[...slug]"
    }
  ],
  "functions": {
    "api/[...slug].js": {
      "maxDuration": 300,
      "includeFiles": "public/*.html"
    }
  },
  "crons": [
    {
      "path": "/api/promote/social/posts/publish-due",
      "schedule": "*/5 * * * *"
    }
  ]
}
