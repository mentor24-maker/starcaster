{
  "version": 2,

  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/[...slug].js"
    },
    {
      "src": "/$",
      "dest": "/public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate, max-age=0, s-maxage=0"
        }
      ]
    }
  ],
  "functions": {
    "api/[...slug].js": {
      "maxDuration": 300
    }
  }
}
