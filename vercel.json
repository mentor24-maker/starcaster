{
  "version": 2,
  "routes": [
    {
      "src": "/(.*\\.(?:js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|webp|map|ttf|eot|woff2)$)",
      "dest": "/$1",
      "headers": { "Cache-Control": "public, max-age=86400, stale-while-revalidate=604800" }
    },
    {
      "src": "/images/(.*)",
      "dest": "/images/$1",
      "headers": { "Cache-Control": "public, max-age=86400, stale-while-revalidate=604800" }
    },
    {
      "src": "/app-shell.html",
      "dest": "/api/app-shell.html",
      "headers": { "Cache-Control": "no-cache, no-store, must-revalidate, max-age=0, s-maxage=0" }
    },
    {
      "src": "/",
      "dest": "/index.html",
      "headers": { "Cache-Control": "no-cache, no-store, must-revalidate, max-age=0, s-maxage=0" }
    },
    {
      "src": "/(.*)",
      "dest": "/api/[...slug]",
      "headers": { "Cache-Control": "no-cache, no-store, must-revalidate, max-age=0, s-maxage=0" }
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 300,
      "includeFiles": "public/*.html"
    },
    "api/[...slug].js": {
      "maxDuration": 300,
      "includeFiles": "public/*.html"
    }
  },
  "crons": [
    {
      "path": "/api/promote/social/posts/publish-due",
      "schedule": "*/5 * * * *"
    }
  ]
}
