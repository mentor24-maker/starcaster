# .env.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it to version control.
#
# For production (Vercel): set these in the Vercel dashboard under
#   Project → Settings → Environment Variables
# Or via CLI: vercel env add SUPABASE_URL
# ─────────────────────────────────────────────────────────────────────────────


# ── Supabase ─────────────────────────────────────────────────────────────────
# Your Supabase project URL (from: Supabase dashboard → Settings → API)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Supabase service-role key — has full database access, treat like a password.
# (from: Supabase dashboard → Settings → API → service_role key)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# ── Server (local dev only) ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development


# ── Vercel (optional — only needed if you want the Settings UI to push
#   env vars to Vercel automatically via the API) ─────────────────────────────
# Personal access token from: https://vercel.com/account/tokens
VERCEL_TOKEN=

# Your Vercel project ID (from: Vercel dashboard → Project → Settings → General)
VERCEL_PROJECT_ID=

# Your Vercel team ID — leave blank for personal (hobby) accounts
VERCEL_TEAM_ID=
