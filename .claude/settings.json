{
  "permissions": {
    "allow": [
      "Bash(vercel --version)",
      "Bash(vercel logs *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/scripts/hooks/block_edits_on_main.cjs\"",
            "timeout": 15,
            "statusMessage": "Checking branch (no edits on main)"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/scripts/hooks/block_generated_edits.cjs\"",
            "timeout": 15,
            "statusMessage": "Checking for generated-file edits"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/scripts/hooks/warn_stale_artifacts.cjs\"",
            "timeout": 15,
            "statusMessage": "Checking for stale artifacts"
          }
        ]
      }
    ]
  }
}
