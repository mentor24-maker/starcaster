{
  "compilerOptions": {
    "target": "ES2019",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,
    "isolatedModules": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "paths": {
      "next/image": ["./components/builder/compat/next-image.tsx"],
      "next/link": ["./components/builder/compat/next-link.tsx"],
      "next/navigation": ["./components/builder/compat/next-navigation.ts"],
      "next/dynamic": ["./components/builder/compat/next-dynamic.tsx"],
      "@/lib/admin-fetch": ["./lib/builder-client/adapters/admin-fetch.ts"],
      "@/lib/builder-admin-fetch": ["./lib/builder-client/adapters/builder-admin-fetch.ts"],
      "@/lib/capabilities": ["./lib/builder-client/adapters/capabilities.ts"],
      "@/lib/admin-media": ["./lib/builder-client/adapters/admin-media.ts"],
      "@/lib/use-gallery-media-library": ["./lib/builder-client/adapters/use-gallery-media-library.ts"],
      "@/lib/gallery-media-thumbnail": ["./lib/builder-client/adapters/gallery-media-thumbnail.ts"],
      "@/lib/site-url": ["./lib/builder-client/adapters/site-url.ts"],
      "@/lib/poll-test-mode": ["./lib/builder-client/adapters/poll-test-mode.ts"],
      "@/lib/player-portal": ["./lib/builder-client/adapters/player-portal.ts"],
      "@/lib/player-game-reminders": ["./lib/builder-client/adapters/player-game-reminders.ts"],
      "@/lib/poll-deep-dive": ["./lib/builder-client/adapters/poll-deep-dive.ts"],
      "@/lib/load-poll-category-catalog": ["./lib/builder-client/adapters/load-poll-category-catalog.ts"],
      "@/lib/*": ["./lib/builder-client/*"],
      "@/src/site/home/types": ["./lib/builder-client/site-home/types.ts"],
      "@/src/site/home/partials/*": ["./components/site-home/*"],
      "@/components/player-portal-auth-form": ["./components/builder/stubs/player-portal-auth-form.tsx"],
      "@/components/admin-legacy-reminders-import-panel": ["./components/builder/stubs/admin-legacy-reminders-import-panel.tsx"],
      "@/components/gallery-poll-associate-menu": ["./components/builder/stubs/gallery-poll-associate-menu.tsx"],
      "@/components/player-game-reminder-diagnostics-gate": ["./components/builder/stubs/player-game-reminder-diagnostics-gate.tsx"],
      "@/components/use-site-player-registration": ["./components/builder/stubs/use-site-player-registration.ts"],
      "@/components/poll-deep-dive-content": ["./components/builder/stubs/poll-deep-dive-content.tsx"],
      "@/components/builder/*": ["./components/builder/*"],
      "@/components/*": ["./components/*"]
    }
  },
  "include": [
    "builder-react-entry.tsx",
    "lib/builder-client/**/*.ts",
    "components/**/*.ts",
    "components/**/*.tsx"
  ],
  "exclude": ["node_modules", "public", "**/*.test.ts"]
}
