{
  "name": "starcaster",
  "version": "1.0.0",
  "private": true,
  "description": "StarCaster by Alphire",
  "main": "server.js",
  "scripts": {
    "build:html": "node scripts/build_html.js",
    "build:builder": "node scripts/build_builder_bundle.mjs",
    "typecheck": "tsc --noEmit",
    "test:builder-ui": "vitest run",
    "build": "npm run build:html && npm run build:builder && npx esbuild react-entry.js --bundle --outfile=public/bundle.js --loader:.js=jsx && npx esbuild src/css/main.css --bundle --outfile=public/styles.css",
    "dev": "node scripts/dev.mjs",
    "start": "npm run build:html && npm run build:builder && node server.js",
    "build:richtext": "node scripts/build_richtext_bundle.mjs",
    "import:contacts-csv:dry-run": "node scripts/import_contacts_csv_to_supabase.js",
    "import:contacts-csv:apply": "node scripts/import_contacts_csv_to_supabase.js --apply",
    "backfill:assets-drive-meta:dry-run": "node scripts/backfill_asset_metadata_from_drive.js",
    "backfill:assets-drive-meta:apply": "node scripts/backfill_asset_metadata_from_drive.js --apply",
    "backfill:assets-aspect:dry-run": "node scripts/backfill_asset_aspects.js",
    "backfill:assets-aspect:apply": "node scripts/backfill_asset_aspects.js --apply",
    "backfill:channels-passwords:dry-run": "node scripts/backfill_channels_password_encryption.js",
    "backfill:channels-passwords:apply": "node scripts/backfill_channels_password_encryption.js --apply",
    "migrate:assets-drive-to-blob:dry-run": "node scripts/migrate_assets_drive_to_blob.js",
    "migrate:assets-drive-to-blob:apply": "node scripts/migrate_assets_drive_to_blob.js --apply",
    "assets:thumbnails:dry-run": "node scripts/generate_asset_thumbnails.js",
    "assets:thumbnails:apply": "node scripts/generate_asset_thumbnails.js --apply",
    "verify:import-drive-folder": "node scripts/verify_import_drive_folder_route.js",
    "verify:import-from-fields": "node scripts/verify_import_from_fields_route.js",
    "sync:wyr-tweets-ocr:dry-run": "node scripts/sync_wyr_tweets_from_image_ocr.js",
    "sync:wyr-tweets-ocr:apply": "node scripts/sync_wyr_tweets_from_image_ocr.js --apply",
    "screenshots:platform": "node scripts/capture_platform_screenshots.js",
    "check:vercel-cutover": "node scripts/vercel_cutover_check.js",
    "import:training-context:apply": "node scripts/acquire_knowledge.mjs",
    "sync:dev-logs": "node scripts/sync_dev_logs.mjs",
    "migrate:builder-documents:dry-run": "node scripts/migrate_builder_documents.mjs",
    "migrate:builder-documents:apply": "node scripts/migrate_builder_documents.mjs --apply",
    "migrate:email-templates:dry-run": "node scripts/migrate_email_templates_to_page_templates.mjs",
    "migrate:email-templates:apply": "node scripts/migrate_email_templates_to_page_templates.mjs --apply",
    "test:builder": "node --test scripts/builder/*.test.js",
    "build:builder-template": "node scripts/build_template_bundle.mjs",
    "build:builder-email-render": "node scripts/build_email_render_bundle.mjs",
    "extract:builder-css": "node scripts/extract_builder_css.mjs"
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.9.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "heroicons": "^2.2.0",
    "typescript": "^5.9.3",
    "undraw-svg": "^1.0.0",
    "vitest": "^3.2.6"
  },
  "dependencies": {
    "@google-cloud/vertexai": "^1.12.0",
    "@supabase/supabase-js": "^2.104.1",
    "@tiptap/core": "^3.26.1",
    "@tiptap/extension-color": "^3.26.1",
    "@tiptap/extension-image": "^3.26.1",
    "@tiptap/extension-link": "^3.26.1",
    "@tiptap/extension-table": "^3.26.1",
    "@tiptap/extension-table-cell": "^3.26.1",
    "@tiptap/extension-table-header": "^3.26.1",
    "@tiptap/extension-table-row": "^3.26.1",
    "@tiptap/extension-text-align": "^3.26.1",
    "@tiptap/extension-text-style": "^3.26.1",
    "@tiptap/extension-underline": "^3.26.1",
    "@tiptap/pm": "^3.26.1",
    "@tiptap/react": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "@vercel/blob": "^1.1.1",
    "canvas-confetti": "^1.9.4",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.2",
    "imap-simple": "^5.1.0",
    "isomorphic-dompurify": "^3.16.0",
    "jsdom": "^29.1.1",
    "mailparser": "^3.9.8",
    "playwright": "^1.59.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "simple-icons": "^16.23.0"
  }
}
