{
  "name": "starcaster",
  "version": "1.0.0",
  "private": true,
  "description": "StarCaster by Alphire",
  "main": "server.js",
  "scripts": {
    "build:html": "node scripts/build_html.js",
    "build": "npm run build:html && esbuild react-entry.js --bundle --outfile=public/bundle.js --loader:.js=jsx && esbuild src/css/main.css --bundle --outfile=public/styles.css",
    "dev": "npm run build:html && esbuild react-entry.js --bundle --outfile=public/bundle.js --loader:.js=jsx --watch & esbuild src/css/main.css --bundle --outfile=public/styles.css --watch & node server.js",
    "start": "npm run build:html && node server.js",
    "build:richtext": "node scripts/build_richtext_bundle.mjs",
    "import:contacts-csv:dry-run": "node scripts/import_contacts_csv_to_supabase.js",
    "import:contacts-csv:apply": "node scripts/import_contacts_csv_to_supabase.js --apply",
    "backfill:assets-drive-meta:dry-run": "node scripts/backfill_asset_metadata_from_drive.js",
    "backfill:assets-drive-meta:apply": "node scripts/backfill_asset_metadata_from_drive.js --apply",
    "backfill:assets-aspect:dry-run": "node scripts/backfill_asset_aspects.js",
    "backfill:assets-aspect:apply": "node scripts/backfill_asset_aspects.js --apply",
    "backfill:channels-passwords:dry-run": "node scripts/backfill_channels_password_encryption.js",
    "backfill:channels-passwords:apply": "node scripts/backfill_channels_password_encryption.js --apply",
    "migrate:assets-drive-to-blob:dry-run": "node scripts/migrate_assets_drive_to_blob.js",
    "migrate:assets-drive-to-blob:apply": "node scripts/migrate_assets_drive_to_blob.js --apply",
    "assets:thumbnails:dry-run": "node scripts/generate_asset_thumbnails.js",
    "assets:thumbnails:apply": "node scripts/generate_asset_thumbnails.js --apply",
    "verify:import-drive-folder": "node scripts/verify_import_drive_folder_route.js",
    "verify:import-from-fields": "node scripts/verify_import_from_fields_route.js",
    "sync:wyr-tweets-ocr:dry-run": "node scripts/sync_wyr_tweets_from_image_ocr.js",
    "sync:wyr-tweets-ocr:apply": "node scripts/sync_wyr_tweets_from_image_ocr.js --apply",
    "check:vercel-cutover": "node scripts/vercel_cutover_check.js",
    "import:training-context:apply": "node scripts/acquire_knowledge.mjs",
    "sync:dev-logs": "node scripts/sync_dev_logs.mjs"
  },
  "devDependencies": {
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0"
  },
  "dependencies": {
    "@google-cloud/vertexai": "^1.12.0",
    "@supabase/supabase-js": "^2.104.1",
    "@tiptap/core": "^3.22.2",
    "@tiptap/extension-link": "^3.22.2",
    "@tiptap/extension-text-align": "^3.22.2",
    "@tiptap/extension-underline": "^3.22.2",
    "@tiptap/starter-kit": "^3.22.2",
    "@vercel/blob": "^1.1.1",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.2",
    "imap-simple": "^5.1.0",
    "jsdom": "^29.1.1",
    "mailparser": "^3.9.8",
    "playwright": "^1.59.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5"
  }
}
